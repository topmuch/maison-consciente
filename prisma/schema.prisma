/* ═══════════════════════════════════════════════════════
   MAISON CONSCIENTE V1 — Prisma Schema
   Ready for PostgreSQL (change provider + url for prod)
   ═══════════════════════════════════════════════════════ */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"          // "postgresql" en production
  url      = env("DATABASE_URL")
}

enum ReminderType {
  general
  medication
  birthday
  appointment
}

/* ═══ FOYER ═══ */
model Household {
  id                  String    @id @default(uuid())
  name                String
  type                String    @default("home")      // "home" | "hospitality"
  templateSlug        String    @default("nexus-modern")
  settings            String    @default("{}")        // { "lang":"fr", "accent":"gold", "quietHours":[23,7] }
  stripeCustomerId    String?   @unique
  subscriptionPlan    String    @default("free")      // "free" | "comfort" | "prestige" | "starter" | "pro"
  subscriptionStatus  String    @default("inactive")  // "active" | "trialing" | "past_due" | "canceled"
  subscriptionEndsAt  DateTime?
  /* ═══ SETTINGS V2 — Identity / SEO / Preferences ═══ */
  contactPhone        String?
  contactEmail        String?
  contactAddress      String?
  seoTitle            String?
  seoDescription      String?
  seoKeywords         String    @default("[]")        // JSON array: ["smart-home", "luxury"]
  seoOgImage          String?
  timezone            String    @default("Europe/Paris")
  isQuietMode         Boolean   @default(false)
  /* ═══ TABLETTE FAMILIALE ═══ */
  displayToken        String?   @unique
  displayEnabled      Boolean   @default(false)
  displayConfig       String    @default("{}")
  coordinates         Json?                                   // { lat: number, lon: number } pour météo localisée
  voiceSettings       Json?     // { "enabled":true, "rate":1.0, "volume":0.8, "language":"fr-FR", "conversationWindow":10 }
  apiSettings         Json?     // {"openMeteo":true,"icecast":true,"foursquare":false,"deepl":false,"news":false,"transit":false}
  modulesConfig       Json?     // { "roomService":{"active":false,"status":"pending"}, "activities":{"active":false,"status":"pending"}, "wellness":{"active":false,"status":"pending"} }
  notificationPrefs   Json?     // NotificationPrefs from notification-config
  notificationLog     Json?     // NotificationLogEntry[] from notification-config
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt @default(now())
  users               User[]
  zones               Zone[]
  messages            Message[]
  recipes             Recipe[]
  soundscapes         Soundscape[]
  pointsOfInterest    PointOfInterest[]
  emergencyContacts   EmergencyContact[]
  guestAccesses       GuestAccess[]
  maintenanceTasks    MaintenanceTask[]
  groceryItems        GroceryItem[]
  secretVaults        SecretVault[]
  purchaseHistory     PurchaseHistory[]
  ritualTasks         RitualTask[]
  checkInStates       CheckInState[]
  travelJournals      TravelJournal[]
  stayFeedbacks       StayFeedback[]
  userLogs            UserLog[]
  invoices            Invoice[]
  supportTickets      SupportTicket[]
  internalFeedbacks   InternalFeedback[]
  calendarEvents      CalendarEvent[]
  voiceLogs           VoiceLog[]
  appointments        Appointment[]
  reminders           Reminder[]
  knowledgeBase       KnowledgeBaseItem[]
  activities          Activity[]
  safeArrivals        SafeArrival[]
  whatsappNumber      String?
  /* ═══ MEMORY & PREFERENCES (Maellis) ═══ */
  userPreferences     Json?     // { "musicGenre":"jazz", "zodiacSign":null, "dietaryRestrictions":[], "learningMode":true, "knownInterests":[] }
  /* ═══ HOSPITALITY EXTENDED ═══ */
  googlePlaceId       String?
  googleRating        Float?
  reviewSettings      String   @default("{}")
  contactSettings     String   @default("{}")
  /* ═══ HOSPITALITY MODULES PAID ═══ */
  dailyChecks         DailyCheck[]
  stayReviewReports   StayReviewReport[]
  hostAlerts          HostAlert[]
  guestProfiles       GuestProfile[]
  /* ═══ CALENDRIER INTELLIGENT ═══ */
  calendarSources      CalendarSource[]
  syncedBookings       SyncedBooking[]
  /* ═══ GÉOLOCALISATION FAMILLE ═══ */
  familyMembers        FamilyMember[]
  geoFences            GeoFence[]
  locationLogs         LocationLog[]
  /* ═══ SMART SHOP ═══ */
  shoppingLists         ShoppingList[]
  shoppingListItems     ShoppingListItem[]
  partnerStores         PartnerStore[]
  priceHistories         PriceHistory[]
}

/* ═══ GUEST PROFILE — Mémoire Voyageurs (Hospitalité) ═══ */
model GuestProfile {
  id             String   @id @default(uuid())
  householdId    String
  guestName      String                           // Nom complet (clé de recherche)
  email          String?                          // Email si disponible
  phone          String?                          // Téléphone si disponible
  nationality     String?                          // Pays d'origine (pour Auto Language Adapt)
  preferredLang  String   @default("fr-FR")       // Langue préférée
  visitCount     Int      @default(1)              // Nombre de séjours
  lastVisitAt    DateTime @default(now())
  /* ═══ PRÉFÉRENCES ═══ */
  temperature    String?                          // "froid", "tempéré", "chaud"
  pillowType     String?                          // "dur", "moyen", "moelleux"
  dietaryRestrictions String @default("[]")     // JSON array: ["végétarien", "sans gluten"]
  musicGenre     String?                          // "jazz", "classique", etc.
  knownInterests String   @default("[]")        // JSON array: ["yoga", "randonnée"]
  notes          String?                          // Notes libres de l'hôte
  createdAt      DateTime @default(now())
  updatedAt      DateTime  @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, guestName])
  @@index([nationality])
  @@index([lastVisitAt(sort: Desc)])
}

/* ═══ CHECK-IN / CHECK-OUT DIGITAL (Hospitalité) ═══ */
model CheckInState {
  id          String    @id @default(uuid())
  householdId String
  guestName   String
  checkInAt   DateTime  @default(now())
  checkOutAt  DateTime?
  status      String    @default("checked-in") // "checked-in" | "checked-out" | "pending"
  notes       String?
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, status])
  @@index([checkInAt(sort: Desc)])
}

/* ═══ CARNET DE SÉJOUR (Hospitalité) ═══ */
model TravelJournal {
  id          String   @id @default(uuid())
  householdId String
  guestId     String?                      // null si accès invité
  title       String
  content     String                        // Markdown
  photos      String   @default("[]")      // JSON array of URLs
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt(sort: Desc)])
}

/* ═══ AVIS POST-SÉJOUR (Hospitalité) ═══ */
model StayFeedback {
  id          String   @id @default(uuid())
  householdId String
  stayRef     String                        // Référence booking ou CheckInState ID
  rating      Int                            // 1-5 global
  cleanliness Int                            // 1-5
  comfort     Int                            // 1-5
  location    Int                            // 1-5
  comment     String?
  submittedAt DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, submittedAt(sort: Desc)])
}

/* ═══ UTILISATEUR ═══ */
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String    @default("")
  role         String    @default("member") // "member" | "owner" | "superadmin"
  avatar       String?
  householdId  String?
  preferences  String    @default("{}")     // { "haptic":true, "theme":"dark" }
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  household    Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sessions     Session[]
  interactions Interaction[]
  messagesSent Message[] @relation("SentMessages")
  moodEntries  MoodEntry[]
  userLogs     UserLog[]

  @@index([householdId])
}

/* ═══ SESSION (Lucia Auth) ═══ */
model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/* ═══ ZONE (QR / NFC) ═══ */
model Zone {
  id          String   @id @default(uuid())
  householdId String
  name        String                    // "Entrée", "Salon", "Cuisine"
  icon        String    @default("home")
  color       String    @default("#d4a853")
  qrCode      String    @unique         // Slug public ex: "salon-abc123"
  nfcUid      String?   @unique
  config      String    @default("{}")  // { "activeHours":[8,23], "mood":"relax" }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  interactions Interaction[]

  @@index([householdId])
}

/* ═══ INTERACTION (Scan) ═══ */
model Interaction {
  id        String   @id @default(uuid())
  zoneId    String
  userId    String
  createdAt DateTime @default(now())
  context   String   @default("{}")  // { "hour":20, "weather":"clear", "weekday":"ven" }
  response  String?  @default("{}")  // { "suggestion":"Musique", "recipe":{...} }
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([zoneId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

/* ═══ MESSAGE (Mur du foyer) ═══ */
model Message {
  id          String   @id @default(uuid())
  householdId String
  senderId    String?
  content     String
  type        String   @default("note")  // "note" | "alert" | "reminder"
  isRead      Boolean  @default(false)
  isPublic    Boolean  @default(false)  // Affiché uniquement sur la tablette
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sender      User?     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt(sort: Desc)])
  @@index([senderId])
}

/* ═══ RECETTE ═══ */
model Recipe {
  id          String   @id @default(uuid())
  householdId String?                  // Null = globale
  title       String
  description String   @default("")
  prepTimeMin Int      @default(0)
  tags        String   @default("[]")  // JSON array: ["dessert","rapide"]
  ingredients String   @default("[]")  // JSON array
  steps       String   @default("[]")  // JSON array
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  household   Household? @relation(fields: [householdId], references: [id])
  translations RecipeTranslation[]

  @@index([isActive, householdId])
}

/* ═══ POINT D'INTÉRÊT (Hospitalité) ═══ */
model PointOfInterest {
  id           String   @id @default(uuid())
  householdId  String
  name         String
  category     String                      // "coffee" | "restaurant" | "pharmacy" | "activity" | "museum" | "spa" | "bar" | "nightlife" | "market" | "park" | "cafe" | "transport"
  distanceMin  Int                          // en minutes à pied
  description  String   @default("")
  rating       Float?
  imageUrl     String?
  address      String   @default("")
  tags         String   @default("[]")      // JSON array: ["indoor", "rainy-day", "family", "romantic"]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, category])
}

/* ═══ CONTACT URGENCE ═══ */
model EmergencyContact {
  id          String    @id @default(uuid())
  householdId String
  name        String
  phone       String
  type        String    @default("emergency") // "emergency" | "service" | "family"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

/* ═══ ACCÈS INVITÉ ═══ */
model GuestAccess {
  id          String   @id @default(uuid())
  householdId String
  token       String   @unique
  name        String
  expiresAt   DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

/* ═══ TÂCHE MAINTENANCE ═══ */
model MaintenanceTask {
  id          String   @id @default(uuid())
  householdId String
  title       String
  dueDate     DateTime
  isDone      Boolean  @default(false)
  recurrence  String?                   // "monthly" | "yearly" | null
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, isDone])
}

/* ═══ HUMEUR ═══ */
model MoodEntry {
  id        String   @id @default(uuid())
  userId    String
  mood      Int                        // 1 à 5
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

/* ═══ COURSE ═══ */
model GroceryItem {
  id          String    @id @default(uuid())
  householdId String
  name        String
  isBought    Boolean   @default(false)
  category    String    @default("food") // "food" | "hygiene" | "other" | "dairy" | "bakery" | "meat" | "produce" | "beverages" | "frozen"
  barcode     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, isBought])
}

/* ═══ COFFRE-FORT NUMÉRIQUE ═══ */
model SecretVault {
  id          String   @id @default(uuid())
  householdId String
  title       String                        // ex: "WiFi Salon", "Netflix"
  username    String?
  password    String                        // Chiffré en prod, clair pour MVP local
  type        String   @default("other")    // "wifi" | "streaming" | "banking" | "other"
  isPublic    Boolean  @default(false)       // Affiché sur tablette ?
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

/* ═══ HISTORIQUE D'ACHAT (Suggestions Auto) ═══ */
model PurchaseHistory {
  id          String   @id @default(uuid())
  householdId String
  itemName    String
  boughtAt    DateTime @default(now())
  category    String?
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, itemName])
}

/* ═══ RITUEL QUOTIDIEN ═══ */
model RitualTask {
  id          String   @id @default(uuid())
  householdId String
  title       String
  timeOfDay   String   @default("morning") // "morning" | "evening"
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, timeOfDay])
}

/* ═══ LOGS D'AUDIT (Admin) ═══ */
model UserLog {
  id          String   @id @default(uuid())
  userId      String?
  householdId String
  action      String                       // "login", "login_failed", "register", "logout", "settings_update", "vault_access", "subscription_change", "emergency_call", "api_config_update", "safe_arrival_alert", "payment_failed"
  details     String?
  ip          String?
  country     String?  @default("unknown") // Auto-detected from x-vercel-ip-country
  city        String?                         // Future: geo-IP lookup
  userAgent   String?                         // Browser / client User-Agent
  status      String?  @default("success")  // "success" | "failure" | "security_alert"
  createdAt   DateTime @default(now())
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt(sort: Desc)])
  @@index([action])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
}

/* ═══ FACTURE (Stripe) ═══ */
model Invoice {
  id              String   @id @default(uuid())
  householdId     String
  stripeInvoiceId String?  @unique
  amountCents     Int
  currency        String   @default("eur")
  status          String   @default("paid")  // "paid" | "open" | "past_due" | "void"
  pdfUrl          String?
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime @default(now())
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([status])
}

/* ═══ TRADUCTION DE RECETTE (DeepL) ═══ */
model RecipeTranslation {
  id          String   @id @default(uuid())
  recipeId    String
  targetLang  String                       // "en", "es", "de", etc.
  title       String
  ingredients String                       // JSON string translated
  steps       String                       // Translated steps
  createdAt   DateTime @default(now())
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, targetLang])
  @@index([recipeId])
}

/* ═══ SOUNDSCAPE (Ambiance sonore) ═══ */
model Soundscape {
  id          String   @id @default(uuid())
  householdId String?                  // Null = bibliothèque globale
  title       String
  category    String   @default("nature")  // "nature" | "instrumental" | "urban"
  sourceType  String   @default("local")   // "local" | "youtube"
  url         String                       // /audio/rain.mp3 ou URL
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  household   Household? @relation(fields: [householdId], references: [id])

  @@index([isActive, householdId])
}

/* ═══ CALENDRIER INTELLIGENT — Source de synchronisation ═══ */
model CalendarSource {
  id            String           @id @default(uuid())
  householdId   String
  name          String                              // e.g. "Airbnb", "Booking.com", "Google Calendar"
  type          String                              // "ical" | "airbnb" | "booking" | "google"
  url           String?                             // iCal URL (pour type ical)
  syncToken     String?                             // OAuth token (chiffré, pour types API)
  syncSecret    String?                             // OAuth secret (chiffré, pour types API)
  lastSyncAt    DateTime?
  syncStatus    String           @default("idle")  // "idle" | "syncing" | "error"
  lastError     String?
  isActive      Boolean          @default(true)
  autoSync      Boolean          @default(true)
  syncInterval  Int              @default(60)       // minutes entre les syncs
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  calendarEvents SyncedBooking[]
  household     Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, isActive])
}

/* ═══ CALENDRIER INTELLIGENT — Réservation synchronisée ═══ */
model SyncedBooking {
  id               String    @id @default(uuid())
  householdId      String
  calendarSourceId String
  externalId       String                           // ID externe (Airbnb/Booking)
  guestName        String
  guestEmail       String?
  guestPhone       String?
  checkInDate      DateTime
  checkOutDate     DateTime
  numberOfGuests   Int?
  source           String                           // "airbnb" | "booking" | "google" | "ical"
  status           String    @default("confirmed")  // "confirmed" | "cancelled" | "completed" | "pending"
  notes            String?
  totalPrice       Float?
  currency         String?
  listingName      String?                          // Nom du logement sur la plateforme
  lastSyncedAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  calendarSource   CalendarSource @relation(fields: [calendarSourceId], references: [id], onDelete: Cascade)
  household        Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, status])
  @@index([householdId, checkInDate])
  @@index([calendarSourceId, externalId])
  @@unique([calendarSourceId, externalId])
}

/* ═══ CALENDRIER D'ÉVÉNEMENTS ═══ */
model CalendarEvent {
  id          String   @id @default(uuid())
  householdId String
  title       String
  date        DateTime
  type        String   @default("reminder") // "birthday" | "holiday" | "reminder" | "checkout"
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, date])
}

/* ═══ TICKET SUPPORT (Contact Hôte) ═══ */
model SupportTicket {
  id          String   @id @default(uuid())
  householdId String
  type        String   @default("other")    // "cleaning" | "equipment" | "access" | "other"
  message     String
  photoUrl    String?
  status      String   @default("open")     // "open" | "resolved" | "ignored"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, status])
  @@index([createdAt(sort: Desc)])
}

/* ═══ FEEDBACK INTERNE (Smart Review) ═══ */
model InternalFeedback {
  id          String   @id @default(uuid())
  householdId String
  rating      Int                            // 1-5
  comment     String?
  isExpired   Boolean  @default(false)
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt(sort: Desc)])
}

/* ═══ API CONFIG (SuperAdmin — Services Externes) ═══ */
model ApiConfig {
  id          String   @id @default(uuid())
  serviceKey  String   @unique              // "FOURSQUARE", "DEEPL", "STRIPE", "RESEND", "OPENWEATHER", "GOOGLE_PLACES"
  apiKey      String                         // Chiffré AES-256-GCM
  baseUrl     String?                         // Optionnel, ex: "https://api.foursquare.com"
  isActive    Boolean  @default(true)
  lastTested   DateTime?
  status      String   @default("unknown")    // "ok", "error", "untested"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceKey])
}

/* ═══ VOICE LOG (AI Assistant) ═══ */
model VoiceLog {
  id           String   @id @default(uuid())
  householdId  String
  token        String?
  intent       String
  originalText String
  success      Boolean  @default(false)
  errorMessage String?
  createdAt    DateTime @default(now())
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt(sort: Desc)])
}

/* ═══ APPOINTMENT (Rendez-vous) ═══ */
model Appointment {
  id           String   @id @default(uuid())
  householdId  String
  title        String
  date         DateTime
  location     String?
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, date(sort: Asc)])
}

/* ═══ REMINDER (Rappel) ═══ */
model Reminder {
  id              String       @id @default(uuid())
  householdId     String
  text            String
  triggerAt       DateTime
  type            ReminderType @default(general)
  isRecurring     Boolean      @default(false)
  recurrenceRule  String?
  notified        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  household       Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, triggerAt(sort: Asc)])
}

/* ═══ BASE DE CONNAISSANCE (FAQ Assistant) ═══ */
model KnowledgeBaseItem {
  id          String   @id @default(uuid())
  householdId String
  question    String
  answer      String
  category    String                    // "TV", "WiFi", "Clim", "Cuisine", "Check-in", "Sécurité", "Machine à laver", etc.
  room        String?                   // "Salon", "Chambre 1", "Cuisine", "SDB", etc.
  keywords    String   @default("[]")   // JSON array: ["télé", "tv", "allumer", "marche pas"]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, category])
  @@index([isActive])
}

/* ═══ ACTIVITÉ & SORTIES (Conciergerie) ═══ */
model Activity {
  id             String   @id @default(uuid())
  householdId    String
  title          String
  category       String                        // Culture, Sport, Nature, Gastronomie, Bien-être, Shopping, Transport, Loisir
  description    String?                       // Description détaillée (markdown)
  distance       String?                       // Ex: "À 10 min à pied"
  link           String?                       // URL externe (Google Maps, site web, etc.)
  isPartner      Boolean  @default(false)      // Badge "Partenaire" doré
  whatsappNumber String?                       // Numéro WhatsApp pour réservation
  image          String?                       // URL image ou base64 (MVP)
  priceHint      String?                       // Ex: "Gratuit", "~15€", "20-50€"
  hoursHint      String?                       // Ex: "09h-18h", "Sur rendez-vous"
  address        String?                       // Adresse pour Google Maps intent
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, category])
  @@index([isPartner])
}

/* ═══ SYSTEM CONFIG (SuperAdmin — Platform Settings) ═══ */
model SystemConfig {
  id          String   @id @default(uuid())
  category    String                       // "smtp" | "sentry" | "general"
  key         String   @unique              // "smtp_host", "sentry_dsn", "platform_name", etc.
  value       String   @default("")         // Encrypted for secrets, plain for non-secrets
  isSecret    Boolean  @default(false)      // If true, value is AES-256-GCM encrypted
  label       String                       // Display label: "Hôte SMTP", "Sentry DSN"
  description String   @default("")         // Help text shown in admin UI
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
}

/* ═══ SAFE ARRIVAL (Sécurité Familiale) ═══ */
model SafeArrival {
  id             String   @id @default(uuid())
  householdId    String
  memberId       String                      // User ID or custom member name
  memberName     String                      // Display name
  status         String   @default("pending") // "pending" | "arrived" | "late" | "emergency"
  expectedBefore DateTime                     // Expected arrival time
  arrivedAt      DateTime?                    // Actual arrival time
  acknowledgedAt DateTime?                    // When the arrival was acknowledged
  isLate         Boolean  @default(false)
  lateMinutes    Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, status])
  @@index([expectedBefore])
}

/* ═══ FAMILY MEMBER — Membre de la famille (Géolocalisation) ═══ */
model FamilyMember {
  id                String    @id @default(uuid())
  householdId       String
  userId            String?                           // Lien optionnel vers un User
  name              String                            // Nom d'affichage
  role              String    @default("Parent")       // "Parent" | "Child" | "Elderly" | "Other"
  avatarColor       String    @default("#d4a853")      // Couleur d'avatar pour la carte
  trackingToken     String    @unique                  // Token unique pour l'API mobile (UUID)
  consentGiven      Boolean   @default(false)          // Consentement obligatoire pour activer le tracking
  consentGivenAt    DateTime?                         // Date du consentement
  consentRevokedAt  DateTime?                         // Date de révocation
  isActive          Boolean   @default(true)           // Peut être désactivé instantanément
  lastKnownLat      Float?                            // Dernière latitude connue
  lastKnownLng      Float?                            // Dernière longitude connue
  lastKnownAt       DateTime?                         // Timestamp de la dernière position
  lastKnownAccuracy Float?                            // Précision GPS en mètres
  currentGeoFenceId String?                           // Zone actuelle (si dans une GeoFence)
  status            String    @default("offline")      // "home" | "away" | "school" | "work" | "offline" | "en_route"
  batteryLevel      Int?                              // Niveau de batterie du téléphone (%)
  expectedHomeBefore DateTime?                         // Heure prévue de retour à la maison
  autoDeleteDays    Int       @default(7)              // Jours de rétention des logs (RGPD)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  locationLogs      LocationLog[]
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, isActive])
  @@index([trackingToken])
  @@index([householdId, status])
  @@index([lastKnownAt(sort: Desc)])
}

/* ═══ GEO FENCE — Zone géographique définie ═══ */
model GeoFence {
  id            String   @id @default(uuid())
  householdId   String
  name          String                            // "Maison", "École", "Travail", "Gym"
  type          String   @default("home")          // "home" | "school" | "work" | "custom"
  centerLat     Float                             // Latitude du centre
  centerLng     Float                             // Longitude du centre
  radiusMeters  Float    @default(200)              // Rayon en mètres (cercle)
  address       String?                           // Adresse lisible
  color         String   @default("#22c55e")      // Couleur d'affichage sur la carte
  isActive      Boolean  @default(true)
  notifyOnEntry Boolean  @default(true)            // Notification quand un membre entre
  notifyOnExit  Boolean  @default(false)           // Notification quand un membre sort
  haSceneOnEntry String?                           // Scène HA à déclencher à l'entrée (ex: "scene.welcome_home")
  haSceneOnExit  String?                           // Scène HA à déclencher à la sortie
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, isActive])
  @@index([type])
}

/* ═══ LOCATION LOG — Historique sécurisé de localisation (RGPD) ═══ */
model LocationLog {
  id          String   @id @default(uuid())
  memberId    String
  householdId String
  lat         Float                             // Latitude
  lng         Float                             // Longitude
  accuracy    Float?                            // Précision GPS en mètres
  speed       Float?                            // Vitesse en m/s
  heading     Float?                            // Direction en degrés
  battery     Int?                              // Niveau de batterie (%)
 event       String   @default("update")        // "update" | "enter" | "exit" | "idle"
 geoFenceId  String?                           // Zone concernée (si enter/exit)
 geoFenceName String?                           // Nom de la zone (snapshot au moment du log)
 createdAt   DateTime @default(now())
  expiresAt   DateTime                          // Date de suppression automatique (RGPD)
  member      FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  household   Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt(sort: Desc)])
  @@index([householdId, createdAt(sort: Desc)])
  @@index([event])
  @@index([expiresAt])
}

/* ═══ DAILY CHECK — Audit Quotidien Concierge (Hospitalité) ═══ */
model DailyCheck {
  id             String    @id @default(uuid())
  householdId    String
  checkInStateId String?                          // Lien vers le CheckInState actif
  guestName      String                           // Nom de l'invité interrogé
  checkDate      DateTime  @default(now())        // Date/heure du check
  checkType      String    @default("daily")      // "arrival" | "daily" | "departure"
  status         String    @default("pending")    // "pending" | "calling" | "completed" | "no_answer" | "failed"
  /* ═══ RÉSULTATS DE L'APPEL ═══ */
  callId         String?                          // Retell AI call ID
  durationSec    Int?                             // Durée de l'appel en secondes
  transcription  String?                          // Transcription brute de Retell
  answeredAt     DateTime?                        // Moment où l'invité a répondu
  /* ═══ DÉTECTION DE PROBLÈMES ═══ */
  overallScore   Int?                             // Note globale 1-5 extraite par Gemini
  sentiment      String?   @default("neutral")    // "positive" | "neutral" | "negative" | "critical"
  issues         String    @default("[]")         // JSON array: ["climatisation défaillante", "bruit extérieur"]
  keywords       String    @default("[]")         // JSON array: mots-clés extraits
  aiSummary      String?                          // Résumé généré par Gemini
  /* ═══ FLAGS ═══ */
  hostAlerted    Boolean   @default(false)        // Alerte hôte déclenchée?
  resolved       Boolean   @default(false)        // Problème résolu par l'hôte?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, checkDate(sort: Desc)])
  @@index([checkInStateId])
  @@index([status])
  @@index([sentiment])
}

/* ═══ STAY REVIEW REPORT — Rapport IA Complet (Hospitalité) ═══ */
model StayReviewReport {
  id             String    @id @default(uuid())
  householdId    String
  checkInStateId String    @unique                // Un rapport par séjour
  guestName      String
  checkInAt      DateTime
  checkOutAt     DateTime?
  /* ═══ NOTES PAR CATÉGORIE (extraites par Gemini) ═══ */
  cleanliness    Int?                             // 1-5 Propreté
  comfort        Int?                             // 1-5 Confort (lit, literie)
  equipment      Int?                             // 1-5 Équipement (WiFi, clim, TV)
  location       Int?                             // 1-5 Emplacement / Accessibilité
  hostContact    Int?                             // 1-5 Contact avec l'hôte
  valueForMoney  Int?                             // 1-5 Rapport qualité-prix
  overallScore   Float?                           // Note moyenne pondérée
  /* ═══ ANALYSE SENTIMENT ═══ */
  sentiment      String    @default("neutral")    // "positive" | "neutral" | "negative" | "critical"
  sentimentScore Float?                           // -1.0 à 1.0 (négatif à positif)
  verbatim       String?                          // Citation directe la plus marquante
  highlights     String    @default("[]")         // JSON array: points positifs
  painPoints     String    @default("[]")         // JSON array: points négatifs / problèmes
  keywords       String    @default("[]")         // JSON array: mots-clés fréquents
  /* ═══ RAPPORT IA ═══ */
  aiSummary      String?                          // Résumé narratif généré par Gemini
  recommendation String?                          // Suggestion d'amélioration
  publicReview   String?                          // Brouillon d'avis public positif
  /* ═══ MÉTADONNÉES ═══ */
  dailyCheckCount Int      @default(0)            // Nombre de daily checks effectués
  totalAlerts    Int       @default(0)            // Nombre d'alertes déclenchées
  resolvedAlerts Int       @default(0)            // Alertes résolues
  generatedAt    DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, generatedAt(sort: Desc)])
  @@index([checkInStateId])
  @@index([sentiment])
}

/* ═══ HOST ALERT — Alerte Hôte en Temps Réel ═══ */
model HostAlert {
  id             String    @id @default(uuid())
  householdId    String
  dailyCheckId   String?                          // Check ayant déclenché l'alerte
  checkInStateId String?                          // Séjour concerné
  guestName      String
  severity       String    @default("medium")     // "low" | "medium" | "high" | "critical"
  category       String                           // "cleanliness" | "equipment" | "noise" | "safety" | "comfort" | "other"
  message        String                           // Description du problème détecté
  transcription  String?                          // Transcription source
  status         String    @default("pending")    // "pending" | "sent" | "acknowledged" | "resolved" | "dismissed"
  /* ═══ NOTIFICATION ═══ */
  notifiedVia    String?                          // "retell_call" | "push" | "email"
  notifiedAt     DateTime?
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  resolution     String?                          // Commentaire de résolution
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt(sort: Desc)])
  @@index([status])
  @@index([severity])
}

/* ═══ SMART SHOP — Liste de courses intelligente ═══ */
model ShoppingList {
  id              String   @id @default(uuid())
  householdId     String
  name            String   @default("Mes courses")
  budgetCents     Int      @default(0)              // Budget en centimes (0 = pas de budget)
  spentCents      Int      @default(0)              // Total des items cochés (achetés)
  storeName       String?
  status          String   @default("active")       // "active" | "completed" | "archived"
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items           ShoppingListItem[]

  @@index([householdId, status])
  @@index([householdId, startedAt(sort: Desc)])
}

/* ═══ SMART SHOP — Article de la liste de courses ═══ */
model ShoppingListItem {
  id              String   @id @default(uuid())
  householdId     String
  listId          String
  barcode         String?
  productName     String
  brand           String?
  priceCents      Int      @default(0)              // Prix unitaire en centimes
  quantity        Int      @default(1)
  unit            String   @default("pièce")        // "pièce" | "kg" | "litre" | "pack" | "boîte" | "sachet"
  category        String?                           // "légumes" | "viande" | "hygiène" | "produits laitiers" | "boulangerie" | "boissons" | "surgelés" | "alimentaire" | "autre"
  imageUrl        String?
  isChecked       Boolean  @default(false)          // Coché = dans le panier / acheté
  checkedAt       DateTime?                         // Quand l'item a été coché
  suggestedBy     String   @default("user")         // "user" | "ai" | "recipe" | "voice" | "routine"
  linkedStoreId   String?                           // Partenaire suggéré pour cet item
  notes           String?                           // Notes libres (ex: "marque X uniquement")
  scannedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  list            ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  linkedStore     PartnerStore?  @relation(fields: [linkedStoreId], references: [id], onDelete: SetNull)

  @@index([listId, checkedAt(sort: Desc)])
  @@index([listId, isChecked])
  @@index([householdId, barcode])
  @@index([productName])
}

/* ═══ SMART SHOP — Magasin partenaire ═══ */
model PartnerStore {
  id                  String   @id @default(uuid())
  householdId         String
  name                String                          // "Carrefour", "Leclerc", "Maellis Market"
  logo                String?                         // URL du logo
  deliveryApiEndpoint String?                         // URL de l'API de commande (futur)
  categoriesMapping   String   @default("{}")          // JSON: { "légumes": "fruits-legumes", "viande": "boucherie" }
  deepLinkTemplate    String?                         // Template URL deep link: "https://...?q={items}"
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  shoppingListItems   ShoppingListItem[]

  @@index([householdId, isActive])
}

/* ═══ SMART SHOP — Historique de prix par barcode ═══ */
model PriceHistory {
  id           String   @id @default(uuid())
  householdId  String
  barcode      String
  productName  String
  priceCents   Int
  storeName    String?
  recordedAt   DateTime @default(now())
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, barcode])
  @@index([barcode, recordedAt(sort: Desc)])
}
